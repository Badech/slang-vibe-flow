# ── Neon (Postgres) ─────────────────────────────────────────────────────────
# Use the POOLED connection string (ends with `-pooler.<region>.neon.tech`)
# for serverless compatibility on Vercel/Cloudflare edge.
NEON_DATABASE_URL=postgres://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require

# ── Clerk (auth) ────────────────────────────────────────────────────────────
# Vite exposes anything prefixed with VITE_ to the client. The publishable key
# is safe to ship to the browser; the secret key is server-only.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxx

# ── App config ──────────────────────────────────────────────────────────────
VITE_APP_URL=http://localhost:5173
